; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Phone wars"
run/main_scene="uid://bnn04m70vruxa"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

Const="*res://scripts/globals/const.gd"
AudioService="*uid://bq66fyhh6afgc"
DebugManager="*uid://ckgtycqmy0lin"

[display]

window/size/viewport_width=448
window/size/viewport_height=280
window/size/resizable=false
window/stretch/mode="canvas_items"

[file_customization]

folder_colors={
"res://assets/": "orange",
"res://scenes/": "green",
"res://scripts/": "blue",
"res://tilesets/": "yellow"
}

[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

2d_physics/layer_1="Terrain"
2d_physics/layer_2="Unit"
2d_physics/layer_3="Building"

[limbo_ai]

behavior_tree/behavior_tree_default_dir="res://resources/ai"
behavior_tree/user_task_dirs=PackedStringArray("res://ai/tasks", "res://scripts/ai/tasks")

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
